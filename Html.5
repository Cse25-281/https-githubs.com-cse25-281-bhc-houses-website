<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BHC - Botswana Housing Corporation</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

  <!-- HEADER: Top navigation bar -->
  <header>
    <div class="container">
      <div class="logo">BHC</div>
      <nav>
        <ul>
          <li><a href="#">Home</a></li>
          <li><a href="#">Properties</a></li>
          <li><a href="#">Contact</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <!-- MAIN CONTENT -->
  <main>
    
    <!-- HERO SECTION -->
    <section class="hero">
      <h1>Find Your Dream House</h1>
      <p>Quality housing solutions across Botswana</p>
      <a href="#" class="button">Browse Properties</a>
    </section>

    <!-- FEATURED PROPERTIES SECTION -->
    <section class="featured-properties">
      <h2>Featured Properties</h2>
      
      <!-- PROPERTY CARD 1 -->
      <article class="property-card">
        <img src="images/house1.jpg" alt="3 Bedroom House in Gaborone">
        <div class="card-details">
          <p class="price">P 850,000</p>
          <h3>3 Bedroom House in Gaborone</h3>
          <p>3 Beds | 2 Baths | 120 sqm</p>
          <p>Block 7, Gaborone</p>
          <a href="#" class="button">View Details</a>
        </div>
      </article>

      <!-- PROPERTY CARD 2 -->
      <article class="property-card">
        <img src="images/house2.jpg" alt="4 Bedroom Executive Villa">
        <div class="card-details">
          <p class="price">P 1,200,000</p>
          <h3>4 Bedroom Executive Villa</h3>
          <p>4 Beds | 3 Baths | 200 sqm</p>
          <p>Phakalane, Gaborone</p>
          <a href="#" class="button">View Details</a>
        </div>
      </article>

      <!-- PROPERTY CARD 3 -->
      <article class="property-card">
        <img src="images/house3.jpg" alt="2 Bedroom Apartment">
        <div class="card-details">
          <p class="price">P 650,000</p>
          <h3>2 Bedroom Apartment</h3>
          <p>2 Beds | 1 Bath | 85 sqm</p>
          <p>Mogoditshane</p>
          <a href="#" class="button">View Details</a>
        </div>
      </article>

    </section>
  </main>

  <!-- FOOTER -->
  <footer>
    <p>&copy; 2026 Botswana Housing Corporation. All rights reserved.</p>
  </footer>

</body>
</html>
